# Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_DEBUG=True
FLASK_HOST=localhost
FLASK_PORT=5000

# Ollama Configuration
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# Database Configuration
DB_TYPE=json  # 'json' or 'sqlite'
PRODUCTS_DB_FILE=products_db.json
ALERTS_DB_FILE=alerts_db.json

# API Keys (Optional - for real API integration)
AMAZON_API_KEY=your_amazon_api_key_here
EBAY_API_KEY=your_ebay_api_key_here
PRICE_API_KEY=your_price_api_key_here

# Email Configuration (for price alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_specific_password

# Application Settings
MAX_PRODUCTS_PER_SEARCH=10
DEFAULT_BUDGET=1000
CURRENCY=USD
LOG_LEVEL=INFO

# Feature Flags
ENABLE_REAL_APIS=False
ENABLE_EMAIL_ALERTS=False
ENABLE_PRICE_TRACKING=True
ENABLE_USER_ACCOUNTS=False
